@page "/settings"
@inject HttpClient Http

<PageTitle>Settings — HeartBeat</PageTitle>

<div class="page-header">
    <h1 class="page-title">Settings</h1>
    <span class="page-subtitle">Configure heartbeat and alert parameters</span>
</div>

@if (_settings is null)
{
    <div class="loading-card">
        <div class="spinner"></div>
        <span>Loading settings...</span>
    </div>
}
else
{
    <EditForm Model="_settings" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <div class="settings-grid">

            <div class="settings-card">
                <div class="card-header">
                    <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="2 12 5 12 7 4 9 20 11 11 13 15 15 12 22 12"/>
                    </svg>
                    <h3 class="card-title">Heartbeat</h3>
                </div>

                <div class="field">
                    <label>Folder Path</label>
                    <InputText @bind-Value="_settings.FolderPath" placeholder="C:\Heartbeat" />
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>TX Interval <span class="unit">(seconds)</span></label>
                        <InputNumber @bind-Value="_settings.IntervalSeconds" />
                    </div>
                    <div class="field">
                        <label>RX Check Interval <span class="unit">(seconds)</span></label>
                        <InputNumber @bind-Value="_settings.CheckIntervalSeconds" />
                    </div>
                </div>
                <div class="field" style="max-width:200px">
                    <label>RX Threshold <span class="unit">(seconds)</span></label>
                    <InputNumber @bind-Value="_settings.ThresholdSeconds" />
                </div>
            </div>

            <div class="settings-card">
                <div class="card-header">
                    <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <h3 class="card-title">SMTP Alerts</h3>
                    <label class="toggle">
                        <InputCheckbox @bind-Value="_settings.EnableEmail" />
                        <span class="toggle-track"></span>
                    </label>
                </div>

                <div class="field-row">
                    <div class="field">
                        <label>SMTP Server</label>
                        <InputText @bind-Value="_settings.SmtpServer" placeholder="smtp.example.com" />
                    </div>
                    <div class="field" style="max-width:120px">
                        <label>Port</label>
                        <InputNumber @bind-Value="_settings.Port" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>From</label>
                        <InputText @bind-Value="_settings.From" placeholder="system@example.com" />
                    </div>
                    <div class="field">
                        <label>To</label>
                        <InputText @bind-Value="_settings.To" placeholder="admin@example.com" />
                    </div>
                </div>
            </div>

        </div>

        <div class="form-actions">
            <button type="submit" class="btn-save">
                @if (_saving) { <span class="btn-spinner"></span> }
                Save Changes
            </button>
            @if (_saved)
            {
                <span class="save-confirm">&#10003; Settings saved</span>
            }
        </div>

    </EditForm>
}

<style>
    .page-header  { margin-bottom: 1.75rem; }
    .page-title   { font-size: 1.6rem; font-weight: 700; color: #0f172a; margin: 0 0 2px; }
    .page-subtitle{ font-size: 0.875rem; color: #64748b; }

    .loading-card { display: flex; align-items: center; gap: 12px; padding: 2rem; background: white; border-radius: 12px; color: #64748b; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
    .spinner      { width: 20px; height: 20px; border: 2px solid #e2e8f0; border-top-color: #0ea5e9; border-radius: 50%; animation: spin 0.7s linear infinite; }

    .settings-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem; }

    .settings-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.03);
        border: 1px solid #f1f5f9;
    }

    .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; }
    .card-icon   { width: 20px; height: 20px; color: #0ea5e9; flex-shrink: 0; }
    .card-title  { font-size: 0.95rem; font-weight: 700; color: #0f172a; margin: 0; flex: 1; }

    .toggle { display: flex; align-items: center; cursor: pointer; margin: 0; }
    .toggle input { display: none; }
    .toggle-track {
        width: 36px; height: 20px; background: #cbd5e1; border-radius: 99px;
        transition: background 0.2s; position: relative;
    }
    .toggle-track::after {
        content: ''; position: absolute; top: 3px; left: 3px;
        width: 14px; height: 14px; background: white; border-radius: 50%; transition: transform 0.2s;
    }
    .toggle input:checked ~ .toggle-track { background: #0ea5e9; }
    .toggle input:checked ~ .toggle-track::after { transform: translateX(16px); }

    .field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 1rem; }
    .field label { font-size: 0.8rem; font-weight: 600; color: #475569; }
    .field .unit  { font-weight: 400; color: #94a3b8; }
    .field ::deep input[type=text],
    .field ::deep input[type=number] {
        padding: 8px 12px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.875rem;
        color: #0f172a;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
        background: #f8fafc;
        width: 100%;
    }
    .field ::deep input:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14,165,233,0.12);
        background: white;
    }

    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

    .form-actions { display: flex; align-items: center; gap: 1rem; }

    .btn-save {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 24px;
        background: #0ea5e9; color: white;
        border: none; border-radius: 8px;
        font-size: 0.875rem; font-weight: 600;
        cursor: pointer; transition: background 0.15s;
    }
    .btn-save:hover  { background: #0284c7; }
    .btn-save:active { background: #0369a1; }

    .btn-spinner { width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; }

    .save-confirm { font-size: 0.875rem; font-weight: 600; color: #22c55e; }

    @@media (max-width: 760px) {
        .settings-grid { grid-template-columns: 1fr; }
        .field-row     { grid-template-columns: 1fr; }
    }
</style>

@code {
    private SettingsDto? _settings;
    private bool _saved;
    private bool _saving;

    protected override async Task OnInitializedAsync()
    {
        _settings = await Http.GetFromJsonAsync<SettingsDto>("api/settings");
    }

    private async Task SaveAsync()
    {
        _saving = true;
        await Http.PostAsJsonAsync("api/settings", _settings);
        _saving = false;
        _saved = true;
        StateHasChanged();
        await Task.Delay(2500);
        _saved = false;
        StateHasChanged();
    }
}
