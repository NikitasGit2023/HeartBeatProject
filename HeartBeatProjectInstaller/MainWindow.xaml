<Window x:Class="HeartBeatProjectInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Heartbeat Monitoring Installer"
        Width="760" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width"  Value="110"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3" BorderThickness="1"
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="190"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="17*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <!-- ═══ Sidebar ═══ -->
        <Border Grid.Column="0" Grid.RowSpan="2" Background="#1565C0">
            <DockPanel>

                <!-- App title -->
                <StackPanel DockPanel.Dock="Top" Margin="22,28,22,28">
                    <TextBlock Text="♥" FontSize="32" Foreground="White"/>
                    <TextBlock Text="Heartbeat"  FontSize="17" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                    <TextBlock Text="Monitoring" FontSize="17" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Installer"  FontSize="12" Foreground="#90CAF9" Margin="0,3,0,0"/>
                </StackPanel>

                <!-- Step list -->
                <StackPanel DockPanel.Dock="Top" Margin="0,8,0,0">

                    <Border x:Name="Step1Row" Background="Transparent">
                        <StackPanel Orientation="Horizontal" Margin="16,9">
                            <Border x:Name="Step1Dot" Width="22" Height="22" CornerRadius="11"
                                    Background="White" VerticalAlignment="Center">
                                <TextBlock x:Name="Step1Lbl" Text="1" FontSize="11" FontWeight="Bold"
                                           Foreground="#1565C0"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="Step1Text" Text="Welcome" FontSize="13"
                                       Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Step2Row" Background="Transparent">
                        <StackPanel Orientation="Horizontal" Margin="16,9">
                            <Border x:Name="Step2Dot" Width="22" Height="22" CornerRadius="11"
                                    Background="#3D8BE8" VerticalAlignment="Center">
                                <TextBlock x:Name="Step2Lbl" Text="2" FontSize="11" FontWeight="Bold"
                                           Foreground="#B0BEC5"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="Step2Text" Text="Configure" FontSize="13"
                                       Foreground="#B0BEC5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Step3Row" Background="Transparent">
                        <StackPanel Orientation="Horizontal" Margin="16,9">
                            <Border x:Name="Step3Dot" Width="22" Height="22" CornerRadius="11"
                                    Background="#3D8BE8" VerticalAlignment="Center">
                                <TextBlock x:Name="Step3Lbl" Text="3" FontSize="11" FontWeight="Bold"
                                           Foreground="#B0BEC5"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="Step3Text" Text="Install" FontSize="13"
                                       Foreground="#B0BEC5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border x:Name="Step4Row" Background="Transparent">
                        <StackPanel Orientation="Horizontal" Margin="16,9">
                            <Border x:Name="Step4Dot" Width="22" Height="22" CornerRadius="11"
                                    Background="#3D8BE8" VerticalAlignment="Center">
                                <TextBlock x:Name="Step4Lbl" Text="4" FontSize="11" FontWeight="Bold"
                                           Foreground="#B0BEC5"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="Step4Text" Text="Finish" FontSize="13"
                                       Foreground="#B0BEC5" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- Version -->
                <TextBlock DockPanel.Dock="Bottom" Text="v1.0.0"
                           Foreground="#5C8FD6" FontSize="11" Margin="22,0,22,18"/>
            </DockPanel>
        </Border>

        <!-- ═══ Page content ═══ -->
        <ContentControl x:Name="PageContent" Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2"/>

        <!-- ═══ Navigation bar ═══ -->
        <Border Grid.Column="1"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0" Background="White" Grid.ColumnSpan="2" Margin="0,444,0,0" Grid.RowSpan="2">
            <Grid Margin="20,0">
                <Button x:Name="BackButton" Content="← Back"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Style="{StaticResource NavBtn}"
                        Background="White" Foreground="#616161" BorderBrush="#BDBDBD"
                        Click="BackButton_Click"/>
                <Button x:Name="NextButton" Content="Next →"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Style="{StaticResource NavBtn}"
                        Background="#1565C0" Foreground="White" BorderBrush="#1565C0"
                        Click="NextButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
