<UserControl x:Class="HeartBeatProjectInstaller.Pages.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,35,40,20">

            <TextBlock Text="Welcome to the" FontSize="14" Foreground="#757575" Margin="0,0,0,4"/>
            <TextBlock Text="Heartbeat Monitoring" FontSize="26" FontWeight="Bold" Foreground="#1565C0"/>
            <TextBlock Text="Service Installer"   FontSize="26" FontWeight="Bold" Foreground="#1565C0"
                       Margin="0,0,0,22"/>

            <Rectangle Height="2" Fill="#E3F2FD" Margin="0,0,0,22"/>

            <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#424242" LineHeight="22">
                This wizard will guide you through installing the Heartbeat Monitoring
                Windows Service on this machine. The service runs in the background to
                transmit or monitor heartbeat signals between systems.
            </TextBlock>

            <TextBlock Text="Before you begin, make sure:" FontSize="13" FontWeight="SemiBold"
                       Foreground="#212121" Margin="0,22,0,10"/>

            <StackPanel Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Ellipse Width="6" Height="6" Fill="#1565C0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="HeartbeatMonitoring.exe is in this folder" FontSize="13" Foreground="#424242"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Ellipse Width="6" Height="6" Fill="#1565C0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="You are running this installer as Administrator" FontSize="13" Foreground="#424242"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Ellipse Width="6" Height="6" Fill="#1565C0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#424242">
                        Any existing HeartbeatService will be stopped and replaced
                    </TextBlock>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Click Next to continue." FontSize="13" Foreground="#9E9E9E"
                       Margin="0,26,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
