<UserControl x:Class="HeartBeatProjectInstaller.Pages.FinishPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">

        <!-- Icon circle -->
        <Border x:Name="IconCircle" Width="72" Height="72" CornerRadius="36"
                Background="#43A047" HorizontalAlignment="Center" Margin="0,0,0,24">
            <TextBlock x:Name="IconText" Text="✓" FontSize="34" Foreground="White"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <TextBlock x:Name="HeadingText" Text="Installation Complete!"
                   FontSize="22" FontWeight="Bold" Foreground="#212121"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <TextBlock x:Name="BodyText"
                   Text="The HeartbeatService has been installed and started successfully."
                   FontSize="13" Foreground="#616161" TextWrapping="Wrap"
                   TextAlignment="Center" MaxWidth="360" HorizontalAlignment="Center"
                   Margin="0,0,0,30"/>

        <StackPanel x:Name="ManualStartPanel" Visibility="Collapsed" Margin="0,0,0,20">
            <Border Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1"
                    CornerRadius="4" Padding="16,10">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#F57F17"
                           TextAlignment="Center">
                    The service was installed but could not be started automatically.
                    Open Services (services.msc) and start HeartbeatService manually.
                </TextBlock>
            </Border>
        </StackPanel>

        <TextBlock Text="Click Finish to close the installer." FontSize="12"
                   Foreground="#9E9E9E" HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>
