{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Heartbeat": {
    "Mode": "TX",
    "FolderPath": "C:\\Heartbeat",
    "FileNamePrefix": "heartbeat",
    "IntervalSeconds": 30,
    "OverwriteExisting": true,
    "LogFolderPath": "C:\\Heartbeat\\Logs",
    "CheckIntervalSeconds": 30,
    "ThresholdSeconds": 60
  },
  "Alerts": {
    "EnableEmail": true,
    "SmtpServer": "smtp.example.com",
    "Port": 25,
    "From": "system@example.com",
    "To": "admin@example.com"
  }
}
