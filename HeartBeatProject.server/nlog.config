<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Warn"
      internalLogFile="${basedir}/Logs/nlog-internal.txt">

  <!-- Load NLog.Targets.Syslog extension -->
  <extensions>
    <add assembly="NLog.Targets.Syslog" />
  </extensions>

  <variable name="logDir"        value="${basedir}/Logs" />
  <variable name="fileLayout"    value="${longdate} | ${level:uppercase=true} | ${logger:shortName=true} | ${message:withException=true}" />
  <variable name="consoleLayout" value="${time} | ${level:uppercase=true} | ${logger:shortName=true} | ${message}${onexception:inner= | ${exception:format=message}}" />

  <targets async="true">

    <target xsi:type="File"
            name="file"
            fileName="${logDir}/heartbeat_${date:format=yyyyMMdd}.txt"
            archiveFileName="${logDir}/heartbeat_{#}.txt"
            archiveEvery="Day"
            archiveNumbering="Date"
            maxArchiveFiles="30"
            encoding="utf-8"
            layout="${fileLayout}" />

    <target xsi:type="ColoredConsole"
            name="console"
            layout="${consoleLayout}" />

    <!--
      Syslog target (RFC 5424, UDP).
      Server  → read from GDC at log-time so runtime host changes take effect immediately.
      Port    → set programmatically in Program.cs (int property, not a Layout).
      Facility→ set programmatically in Program.cs (enum property, not a Layout).
    -->
    <target xsi:type="Syslog"
            name="syslog">
      <messageCreation>
        <facility>Local0</facility>
      </messageCreation>
      <messageSend>
        <protocol>UDP</protocol>
        <udp>
          <server>${gdc:item=SyslogHost:whenEmpty=localhost}</server>
          <port>514</port>
        </udp>
      </messageSend>
    </target>

  </targets>

  <rules>
    <!--
      SyslogAlert logger is written exclusively by SyslogSender.SendAsync().
      Routes alert messages to the Syslog server only (final=true prevents
      double-writing to file+console — TX/RX services already log there).
    -->
    <logger name="SyslogAlert" minlevel="Warn" writeTo="syslog" final="true" />

    <!-- Suppress noisy ASP.NET Core / runtime info logs -->
    <logger name="Microsoft.*" minlevel="Warning" writeTo="file,console" final="true" />
    <logger name="System.*"    minlevel="Warning" writeTo="file,console" final="true" />

    <!-- Application logs -->
    <logger name="*" minlevel="Information" writeTo="file,console" />
  </rules>

</nlog>
