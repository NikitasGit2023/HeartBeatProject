{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000",
  "Heartbeat": {
    "FolderPath": "C:\\Heartbeat\\Shared\\HeartbeatFiles",
    "FileNamePrefix": "heartbeat",
    "IntervalSeconds": 30,
    "OverwriteExisting": false,
    "LogFolderPath": ""
  },
  "Alerts": {
    "EnableEmail": false,
    "SmtpServer": "",
    "Port": 587,
    "From": "",
    "To": "",
    "Username": "",
    "Password": "",
    "EnableSsl": true,
    "EnableSnmp": false,
    "SnmpHost": "",
    "SnmpPort": 162,
    "Community": "public",
    "EnableSyslog": false,
    "SyslogHost": "",
    "SyslogPort": 514,
    "SyslogFacility": "Local0"
  }
}
