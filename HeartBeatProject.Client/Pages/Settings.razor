@page "/settings"
@implements IDisposable
@inject HttpClient Http
@inject AppState AppState

<PageTitle>Settings — HeartBeat</PageTitle>

<div class="page-header">
    <h1 class="page-title">Settings</h1>
    <span class="page-subtitle">Configure heartbeat and alert parameters</span>
</div>

@if (_settings is null)
{
    <div class="loading-card">
        <div class="spinner"></div>
        <span>Loading settings...</span>
    </div>
}
else
{
    <EditForm Model="_settings" OnValidSubmit="SaveAsync">

        <div class="settings-stack">

            <!-- ── Heartbeat ─────────────────────────────────── -->
            <div class="settings-card">
                <div class="card-header">
                    <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="2 12 5 12 7 4 9 20 11 11 13 15 15 12 22 12"/>
                    </svg>
                    <h3 class="card-title">Heartbeat</h3>
                    @if (AppState.IsLoaded)
                    {
                        <span class="mode-hint">@AppState.Mode mode</span>
                    }
                </div>

                <div class="field">
                    <label>Folder Path</label>
                    <InputText @bind-Value="_settings.FolderPath" placeholder="C:\Heartbeat\Shared\HeartbeatFiles" />
                </div>

                @if (!AppState.IsLoaded || AppState.IsTx)
                {
                    <div class="field-row">
                        <div class="field">
                            <label>TX Interval <span class="unit">(seconds)</span></label>
                            <InputNumber @bind-Value="_settings.IntervalSeconds" />
                        </div>
                        <div class="field">
                            <label>Overwrite Existing</label>
                            <label class="toggle">
                                <InputCheckbox @bind-Value="_settings.OverwriteExisting" />
                                <span class="toggle-track"></span>
                                <span class="toggle-text">@(_settings.OverwriteExisting ? "Single file (overwrite)" : "Timestamped files")</span>
                            </label>
                        </div>
                    </div>
                }

                @if (!AppState.IsLoaded || AppState.IsRx)
                {
                    <div class="field-row">
                        <div class="field">
                            <label>Check Interval <span class="unit">(seconds)</span></label>
                            <InputNumber @bind-Value="_settings.CheckIntervalSeconds" />
                        </div>
                        <div class="field">
                            <label>Alert Threshold <span class="unit">(seconds)</span></label>
                            <InputNumber @bind-Value="_settings.ThresholdSeconds" />
                        </div>
                    </div>
                }
            </div>

            <!-- ── Email Alerts ──────────────────────────────── -->
            <div class="settings-card">
                <div class="card-header">
                    <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                        <polyline points="22,6 12,13 2,6"/>
                    </svg>
                    <h3 class="card-title">Email Alerts</h3>
                    <label class="toggle">
                        <InputCheckbox @bind-Value="_settings.EnableEmail" />
                        <span class="toggle-track"></span>
                    </label>
                </div>

                <div class="field-row">
                    <div class="field">
                        <label>SMTP Server</label>
                        <InputText @bind-Value="_settings.SmtpServer" placeholder="smtp.example.com" />
                    </div>
                    <div class="field port-field">
                        <label>Port</label>
                        <InputNumber @bind-Value="_settings.Port" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>From</label>
                        <InputText @bind-Value="_settings.From" placeholder="system@example.com" />
                    </div>
                    <div class="field">
                        <label>To <span class="unit">(semicolon-separated)</span></label>
                        <InputText @bind-Value="_settings.To" placeholder="admin@example.com" />
                    </div>
                </div>
                <div class="field-row">
                    <div class="field">
                        <label>Username</label>
                        <InputText @bind-Value="_settings.Username" placeholder="smtp-user" />
                    </div>
                    <div class="field">
                        <label>Password</label>
                        <InputText @bind-Value="_settings.Password" type="password" placeholder="••••••••" />
                    </div>
                </div>
                <div class="field">
                    <label>SSL / STARTTLS</label>
                    <label class="toggle">
                        <InputCheckbox @bind-Value="_settings.EnableSsl" />
                        <span class="toggle-track"></span>
                        <span class="toggle-text">@(_settings.EnableSsl ? "Enabled (port 587)" : "Disabled")</span>
                    </label>
                </div>
            </div>

            <!-- ── SNMP Alerts ───────────────────────────────── -->
            <div class="settings-card">
                <div class="card-header">
                    <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="8" rx="2" ry="2"/>
                        <rect x="2" y="14" width="20" height="8" rx="2" ry="2"/>
                        <line x1="6" y1="6" x2="6.01" y2="6"/>
                        <line x1="6" y1="18" x2="6.01" y2="18"/>
                    </svg>
                    <h3 class="card-title">SNMP Trap Alerts</h3>
                    <label class="toggle">
                        <InputCheckbox @bind-Value="_settings.EnableSnmp" />
                        <span class="toggle-track"></span>
                    </label>
                </div>

                <div class="field-row">
                    <div class="field">
                        <label>SNMP Host</label>
                        <InputText @bind-Value="_settings.SnmpHost" placeholder="192.168.1.1" />
                    </div>
                    <div class="field port-field">
                        <label>Port</label>
                        <InputNumber @bind-Value="_settings.SnmpPort" />
                    </div>
                    <div class="field community-field">
                        <label>Community</label>
                        <InputText @bind-Value="_settings.Community" placeholder="public" />
                    </div>
                </div>
            </div>

            <!-- ── Syslog Alerts ─────────────────────────────── -->
            <div class="settings-card">
                <div class="card-header">
                    <svg class="card-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="4 17 10 11 4 5"/>
                        <line x1="12" y1="19" x2="20" y2="19"/>
                    </svg>
                    <h3 class="card-title">Syslog Alerts</h3>
                    <label class="toggle">
                        <InputCheckbox @bind-Value="_settings.EnableSyslog" />
                        <span class="toggle-track"></span>
                    </label>
                </div>

                <div class="field-row">
                    <div class="field">
                        <label>Syslog Host</label>
                        <InputText @bind-Value="_settings.SyslogHost" placeholder="192.168.1.1" />
                    </div>
                    <div class="field port-field">
                        <label>Port</label>
                        <InputNumber @bind-Value="_settings.SyslogPort" />
                    </div>
                    <div class="field community-field">
                        <label>Facility</label>
                        <InputSelect @bind-Value="_settings.SyslogFacility">
                            <option value="Kernel">Kernel</option>
                            <option value="User">User</option>
                            <option value="Daemons">Daemons</option>
                            <option value="Local0">Local0</option>
                            <option value="Local1">Local1</option>
                            <option value="Local2">Local2</option>
                            <option value="Local3">Local3</option>
                            <option value="Local4">Local4</option>
                            <option value="Local5">Local5</option>
                            <option value="Local6">Local6</option>
                            <option value="Local7">Local7</option>
                        </InputSelect>
                    </div>
                </div>
            </div>

        </div>

        @if (_errorMessage is not null)
        {
            <div class="error-banner">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                @_errorMessage
            </div>
        }

        <div class="form-actions">
            <button type="submit" class="btn-save" disabled="@_saving">
                @if (_saving) { <span class="btn-spinner"></span> }
                Save Changes
            </button>
            @if (_saved)
            {
                <span class="save-confirm">&#10003; Settings saved</span>
            }
        </div>

    </EditForm>
}

<style>
    .page-header   { margin-bottom: 1.75rem; }
    .page-title    { font-size: 1.6rem; font-weight: 700; color: #0f172a; margin: 0 0 2px; }
    .page-subtitle { font-size: 0.875rem; color: #64748b; }

    .loading-card { display: flex; align-items: center; gap: 12px; padding: 2rem; background: white; border-radius: 12px; color: #64748b; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
    .spinner      { width: 20px; height: 20px; border: 2px solid #e2e8f0; border-top-color: #0ea5e9; border-radius: 50%; animation: spin 0.7s linear infinite; }

    .settings-stack { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.25rem; }

    .settings-card {
        background: white;
        border-radius: 12px;
        padding: 1.5rem;
        box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.03);
        border: 1px solid #f1f5f9;
    }

    .card-header { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; }
    .card-icon   { width: 20px; height: 20px; color: #0ea5e9; flex-shrink: 0; }
    .card-title  { font-size: 0.95rem; font-weight: 700; color: #0f172a; margin: 0; flex: 1; }

    .mode-hint {
        font-size: 0.7rem; font-weight: 600; color: #94a3b8;
        background: #f1f5f9; padding: 2px 8px; border-radius: 4px;
        text-transform: uppercase; letter-spacing: 0.5px;
    }

    .toggle { display: flex; align-items: center; cursor: pointer; margin: 0; }
    .toggle ::deep input { display: none; }
    .toggle-track {
        width: 36px; height: 20px; background: #cbd5e1; border-radius: 99px;
        transition: background 0.2s; position: relative; flex-shrink: 0;
    }
    .toggle-track::after {
        content: ''; position: absolute; top: 3px; left: 3px;
        width: 14px; height: 14px; background: white; border-radius: 50%; transition: transform 0.2s;
    }
    .toggle ::deep input:checked ~ .toggle-track { background: #0ea5e9; }
    .toggle ::deep input:checked ~ .toggle-track::after { transform: translateX(16px); }
    .toggle-text { font-size: 0.8rem; color: #64748b; margin-left: 10px; }

    .field { display: flex; flex-direction: column; gap: 5px; margin-bottom: 1rem; }
    .field label { font-size: 0.8rem; font-weight: 600; color: #475569; }
    .field .unit  { font-weight: 400; color: #94a3b8; }
    .field ::deep input[type=text],
    .field ::deep input[type=number],
    .field ::deep input[type=password],
    .field ::deep select {
        padding: 8px 12px;
        border: 1.5px solid #e2e8f0;
        border-radius: 8px;
        font-size: 0.875rem;
        color: #0f172a;
        transition: border-color 0.15s, box-shadow 0.15s;
        outline: none;
        background: #f8fafc;
        width: 100%;
    }
    .field ::deep input:focus,
    .field ::deep select:focus {
        border-color: #0ea5e9;
        box-shadow: 0 0 0 3px rgba(14,165,233,0.12);
        background: white;
    }

    .field-row { display: flex; gap: 1rem; flex-wrap: wrap; }
    .field-row .field { flex: 1; min-width: 160px; }
    .port-field      { flex: 0 0 110px !important; min-width: 0 !important; }
    .community-field { flex: 0 0 160px !important; min-width: 0 !important; }

    .error-banner {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 12px 16px;
        background: #fef2f2; border: 1px solid #fecaca;
        border-radius: 8px; color: #dc2626;
        font-size: 0.875rem; margin-bottom: 1rem;
    }
    .error-banner svg { width: 18px; height: 18px; flex-shrink: 0; margin-top: 1px; }

    .form-actions { display: flex; align-items: center; gap: 1rem; }

    .btn-save {
        display: flex; align-items: center; gap: 8px;
        padding: 10px 24px;
        background: #0ea5e9; color: white;
        border: none; border-radius: 8px;
        font-size: 0.875rem; font-weight: 600;
        cursor: pointer; transition: background 0.15s;
    }
    .btn-save:hover    { background: #0284c7; }
    .btn-save:active   { background: #0369a1; }
    .btn-save:disabled { background: #7dd3fc; cursor: not-allowed; }

    .btn-spinner { width: 14px; height: 14px; border: 2px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 0.7s linear infinite; }

    .save-confirm { font-size: 0.875rem; font-weight: 600; color: #22c55e; }

    @@media (max-width: 640px) {
        .field-row { flex-direction: column; }
        .port-field, .community-field { flex: 1 !important; }
    }
</style>

@code {
    private SettingsDto? _settings;
    private bool   _saved;
    private bool   _saving;
    private string? _errorMessage;

    private sealed record ApiError(string Error);

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;

        var t1 = Http.GetFromJsonAsync<StatusDto>("api/status");
        var t2 = Http.GetFromJsonAsync<SettingsDto>("api/settings");

        try { var s = await t1; if (s is not null) AppState.SetMode(s.Mode); } catch { }
        try { var s = await t2; if (s is not null) _settings = s; } catch { }
    }

    private async Task SaveAsync()
    {
        _saving       = true;
        _errorMessage = null;
        _saved        = false;

        var response = await Http.PostAsJsonAsync("api/settings", _settings);
        _saving = false;

        if (response.IsSuccessStatusCode)
        {
            _saved = true;
            StateHasChanged();
            await Task.Delay(2500);
            _saved = false;
        }
        else
        {
            try
            {
                var err = await response.Content.ReadFromJsonAsync<ApiError>();
                _errorMessage = err?.Error ?? "Save failed. Please check your input.";
            }
            catch
            {
                _errorMessage = "Save failed. Please check your input.";
            }
        }

        StateHasChanged();
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
